# API key from https://kontomierz.pl/profil/api (required)
KONTOMIERZ_API_KEY=your_api_key_here

# MCP SSE transport port (default: 9101)
MCP_PORT=9101

# REST API bridge port for smoke/E2E testing (default: 9102)
REST_API_PORT=9102

# Lightweight health check HTTP port (default: 9100)
HEALTH_PORT=9100

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Set to "true", "1", "yes", or "on" to allow write/destructive operations (default: false)
ENABLE_WRITE_OPERATIONS=false

# Set to "1" to bind to 0.0.0.0 (Docker). Requires explicit acknowledgement. (default: unset = 127.0.0.1)
MCP_UNSAFE_PUBLIC_ACCESS_CONFIRMED=0
